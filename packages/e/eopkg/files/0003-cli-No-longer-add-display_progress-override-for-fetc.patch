From 0a5ffd7b8071d89b13fcadf57f7e82d5945f0b5d Mon Sep 17 00:00:00 2001
From: Joey Riches <josephriches@gmail.com>
Date: Sat, 27 Jun 2026 23:51:50 +0100
Subject: [PATCH 3/3] cli: No longer add display_progress override for fetching
 ops

fetcher now prints directly to stdout, the callbacks only exist for
library users.
---
 pisi/cli/__init__.py | 20 +++++++-------------
 1 file changed, 7 insertions(+), 13 deletions(-)

diff --git a/pisi/cli/__init__.py b/pisi/cli/__init__.py
index 50d7f32..202b38b 100644
--- a/pisi/cli/__init__.py
+++ b/pisi/cli/__init__.py
@@ -158,21 +158,15 @@ class CLI(pisi.ui.UI):
 
     def display_progress(self, **ka):
         """display progress of any operation"""
-        if ka["operation"] in ["removing", "rebuilding-db"]:
+        if ka["operation"] in [
+            "removing",
+            "rebuilding-db",
+            "fetching",
+            "fetching_overall",
+        ]:
             return
-        elif ka["operation"] == "fetching":
-            totalsize = "%.1f %s" % pisi.util.human_readable_size(ka["total_size"])
-            out = "\r%-30.50s (%s)%3d%% %9.2f %s [%s]" % (
-                ka["filename"],
-                totalsize,
-                ka["percent"],
-                ka["rate"],
-                ka["symbol"],
-                ka["eta"],
-            )
-            self.output(out)
         else:
-            self.output("\r%s (%d%%)" % (ka["info"], ka["percent"]))
+            self.output("\r%s (%d%%)" % (ka.get("info", ""), ka["percent"]))
 
         if ka["percent"] == 100:
             self.output(pisi.util.colorize(_(" [complete]\n"), "gray"))
-- 
