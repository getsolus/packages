+
+
+class LessPipe(io.TextIOBase):
+    def __init__(self):
+        self.proc = subprocess.Popen(
+            ["less", "-K", "-R", "-"],
+            stdin=subprocess.PIPE,
+            text=True,
+        )
+
+    def write(self, s: str, /) -> int:
+        try:
+            stdin = self.proc.stdin
+            assert stdin is not None
+            stdin.write(s)
+            return len(s)
+        except (BrokenPipeError, OSError):
+            return 0
+
+    def flush(self) -> None:
+        try:
+            stdin = self.proc.stdin
+            assert stdin is not None
+            stdin.flush()
+        except Exception:
+            pass
+
+    def close(self):
+        try:
+            if self.proc.stdin:
+                self.proc.stdin.close()
+        except Exception:
+            pass
+
+        try:
+            self.proc.wait(timeout=0.2)
+        except Exception:
+            try:
+                self.proc.kill()
+            except Exception:
+                pass
+
+
+@contextmanager
+def less_pager():
+    """
+    Context-managed stdout/stderr pager.
+    """
+    pager = LessPipe()
+    try:
+        with redirect_stdout(pager), redirect_stderr(pager):
+            yield pager
+    finally:
+        pager.close()
