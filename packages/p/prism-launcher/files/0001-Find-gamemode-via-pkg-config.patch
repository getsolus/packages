From ea65b95b0296c6bbbf5a1cfb1287b10985d2dba3 Mon Sep 17 00:00:00 2001
From: Ivan Trepakov <liontiger23@gmail.com>
Date: Sun, 14 Jun 2026 08:35:05 +0700
Subject: [PATCH] Find gamemode via pkg-config

---
 launcher/CMakeLists.txt | 8 +++++---
 1 file changed, 5 insertions(+), 3 deletions(-)

diff --git a/launcher/CMakeLists.txt b/launcher/CMakeLists.txt
index c2f5e70..0f1824b 100644
--- a/launcher/CMakeLists.txt
+++ b/launcher/CMakeLists.txt
@@ -1357,9 +1357,11 @@ else()
 endif()
 
 if (CMAKE_SYSTEM_NAME STREQUAL "Linux")
-    target_link_libraries(Launcher_logic
-        gamemode
-    )
+    if(TARGET PkgConfig::gamemode)
+        target_link_libraries(Launcher_logic PkgConfig::gamemode)
+    else()
+        target_link_libraries(Launcher_logic gamemode)
+    endif()
 endif()
 
 target_link_libraries(Launcher_logic
