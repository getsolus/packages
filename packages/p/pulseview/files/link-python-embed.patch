From: Jared Cervantes <jared@jaredcervantes.com>
Date: Mon, 22 Jun 2026 15:08:00 -0400
Subject: [PATCH] Link against Python embed when using libsigrokdecode

libsigrokdecode embeds Python and exposes Python API references, so the
PulseView executable needs to link against python3-embed when decode support
is enabled.

---
 CMakeLists.txt | 1 +
 1 file changed, 1 insertion(+)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 471ed1f0..71273319 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -82,6 +82,7 @@ list(APPEND PKGDEPS "${LIBSR_CXX_BINDING}")
 
 if(ENABLE_DECODE)
 	list(APPEND PKGDEPS libsigrokdecode>=0.5.2)
+	list(APPEND PKGDEPS python3-embed)
 endif()
 
 if(ANDROID)
