<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <id>uk.org.greenend.chiark.sgtatham.putty</id>
    <metadata_license>CC0-1.0</metadata_license>
    <project_license>MIT</project_license>
    <developer id="uk.org.greenend.chiark.sgtatham">
        <name>Simon Tatham</name>
    </developer>
    <name>PuTTY</name>
    <summary>SSH, Telnet and serial client</summary>
    <description>
        <p>
            PuTTY is a free SSH, Telnet, rlogin and serial console client for Linux.
            It includes PuTTY, pterm, Pageant, Plink, PSCP, PSFTP and PuTTYgen.
        </p>
    </description>
    <launchable type="desktop-id">uk.org.greenend.chiark.sgtatham.putty.desktop</launchable>
    <screenshots>
        <screenshot type="default">
            <caption>PuTTY configuration and console</caption>
            <image>https://upload.wikimedia.org/wikipedia/commons/b/b6/PuTTY_Ubuntu.png</image>
        </screenshot>
    </screenshots>
    <url type="homepage">https://www.chiark.greenend.org.uk/~sgtatham/putty/</url>
    <url type="bugtracker">https://www.chiark.greenend.org.uk/~sgtatham/putty/feedback.html#feedback-bugs</url>
    <provides>
        <binary>putty</binary>
        <binary>plink</binary>
        <binary>pscp</binary>
        <binary>psftp</binary>
        <binary>puttygen</binary>
        <binary>pageant</binary>
        <binary>pterm</binary>
    </provides>
    <categories>
        <category>Network</category>
        <category>RemoteAccess</category>
    </categories>
    <keywords>
        <keyword>putty</keyword>
        <keyword>ssh</keyword>
        <keyword>telnet</keyword>
        <keyword>serial</keyword>
        <keyword>terminal</keyword>
        <keyword>remote</keyword>
    </keywords>
    <releases>
        <release version="0.84" date="2026-05-22">
            <description>
                <ul>
                    <li>Security fix: remotely triggerable double-free in RSA key exchange.</li>
                    <li>Security fix: crash in NIST ECDSA signature verification.</li>
                    <li>Security fix: trust sigil handling for Telnet and Rlogin after proxy authentication.</li>
                    <li>Pre-connection command support (e.g. wake-on-LAN or port knocking).</li>
                    <li>Unix: pre-edit text for multi-keystroke Unicode composition.</li>
                    <li>Unix: improved Wayland support for the GUI tools.</li>
                </ul>
            </description>
        </release>
        <release version="0.83" date="2025-02-08">
            <description>
                <ul>
                    <li>Support for ML-KEM post-quantum key exchange.</li>
                    <li>Full Unicode file names in Windows file selector dialogs.</li>
                    <li>Bug fixes for psftp -b, Pageant, login timeouts and terminal input on Unix.</li>
                </ul>
            </description>
        </release>
        <release version="0.82" date="2024-11-27">
            <description>
                <ul>
                    <li>Major Unicode handling refactor for foreign characters outside the system code page.</li>
                    <li>Bug fix: Alt + function key in Xterm 216+ mode sent a spurious escape character.</li>
                </ul>
            </description>
        </release>
        <release version="0.81" date="2024-04-15">
            <description>
                <ul>
                    <li>Security fix for CVE-2024-31497: biased ECDSA-SHA-521 signatures no longer compromise private keys.</li>
                </ul>
            </description>
        </release>
        <release version="0.80" date="2023-12-18">
            <description>
                <ul>
                    <li>Security fix: support for OpenSSH kex-strict protocol modification.</li>
                    <li>Bug fixes for MSI help file lookup and terminal scrollback reset on escape sequences.</li>
                </ul>
            </description>
        </release>
    </releases>
    <content_rating type="oars-1.1"/>
</component>
