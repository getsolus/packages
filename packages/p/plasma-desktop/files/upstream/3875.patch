From 0a7756beb3524f6feadcdfd4b03ed5db24374a1f Mon Sep 17 00:00:00 2001
From: Christoph Wolk <cwo.kde@posteo.net>
Date: Sat, 11 Jul 2026 19:13:50 +0200
Subject: [PATCH] applets/kicker: workaround qml compiler bug

On Solus (and potentially other systems), kicker can get into a state
where the search results will not show up. The proximate cause is that
the visible binding is correctly computed, but the binding is not
actually updated and remains false.

The bug does not seem to happen if the value is stored in a local
variable before returning it.

BUG: 522704
---
 applets/kicker/MenuRepresentation.qml | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git a/applets/kicker/MenuRepresentation.qml b/applets/kicker/MenuRepresentation.qml
index 274106880e..beb31f62eb 100644
--- a/applets/kicker/MenuRepresentation.qml
+++ b/applets/kicker/MenuRepresentation.qml
@@ -300,7 +300,11 @@ PlasmaComponents3.ScrollView {
 
             Layout.fillHeight: true
 
-            visible: searchField.text !== "" && root.runnerModel.count > 0 && !initialDelayTimer.active && root.runnerModel.resultsPresent
+            visible: {
+                // workaround qml compiler bug, see bug 522704
+                const newVisible =  searchField.text !== "" && root.runnerModel.count > 0 && !initialDelayTimer.active && root.runnerModel.resultsPresent;
+                return newVisible;
+            }
 
             spacing: 0
 
