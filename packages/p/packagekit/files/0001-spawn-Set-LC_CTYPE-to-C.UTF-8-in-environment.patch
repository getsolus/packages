From d9b57726e29892422f99eb105821343757ad5218 Mon Sep 17 00:00:00 2001
From: Joey Riches <josephriches@gmail.com>
Date: Mon, 15 Jun 2026 18:05:45 +0100
Subject: [PATCH 1/1] spawn: Set LC_CTYPE to C.UTF-8 in environment

When PackageKit spawns helper backends via g_spawn_async_with_pipes(),
the environment passed to the child process may not include a valid
UTF-8 locale (e.g. LANG set to C).

In those cases, Python (and other runtimes) may initialize
stdout/stderr using the C locale, resulting in ASCII encoding.

Obviously, when encountered with UTF-8 characters the python
backends will produce `UnicodeEncodeError` errors.

A workaround is to enable `KeepEnvironment`. However, it seems quite
safe to set LC_CTYPE to ensure unicode support is picked up.
---
 src/pk-backend-spawn.c | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/src/pk-backend-spawn.c b/src/pk-backend-spawn.c
index 353931159..ab6b812b3 100644
--- a/src/pk-backend-spawn.c
+++ b/src/pk-backend-spawn.c
@@ -736,6 +736,9 @@ pk_backend_spawn_get_envp (PkBackendSpawn *backend_spawn)
 	if (!pk_strzero (locale))
 		g_hash_table_replace (env_table, g_strdup ("LANG"), g_strdup (locale));
 
+	/* Always ensure UTF-8 is available */
+	g_hash_table_replace (env_table, g_strdup ("LC_CTYPE"), g_strdup ("C.UTF-8"));
+
 	/* FRONTEND SOCKET */
 	value = pk_backend_job_get_frontend_socket (backend_spawn->job);
 	if (!pk_strzero (value))
