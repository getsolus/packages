From e5740412942a1f037ebdaf821ac0a4f7e262622b Mon Sep 17 00:00:00 2001
From: Joey Riches <josephriches@gmail.com>
Date: Sat, 27 Jun 2026 23:25:05 +0100
Subject: [PATCH 2/2] backends/eopkg: Emit release as part of packageid version
 in _pkg_to_id

We accidentally didn't append the package release as part of the package
id version in _pkg_to_id causing package id mismatches

E.g.
- resolve() would emit 0ad;0.28.0-62;x86_64;Unstable
- _pkg_to_id() would emit 0ad;0.28.0;x86_64;Unstable

This fixes package id mismatches in the callback system which
incidentally also fixes gnome-software not always displaying progress
bars to the user.
---
 backends/eopkg/eopkgBackend.py | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/backends/eopkg/eopkgBackend.py b/backends/eopkg/eopkgBackend.py
index b93db26e6..d57620bed 100644
--- a/backends/eopkg/eopkgBackend.py
+++ b/backends/eopkg/eopkgBackend.py
@@ -291,7 +291,8 @@ class PackageKitEopkgBackend(PackageKitBaseBackend, PackagekitPackage):
                 repo = "installed"
             else:
                 repo = "local"
-        pkg_id = self.get_package_id(pkg.name, pkg.version, pkg.architecture, repo)
+        version = self.__get_package_version(pkg)
+        pkg_id = self.get_package_id(pkg.name, version, pkg.architecture, repo)
         return pkg_id
 
     def _get_package_obj_from_id(self, package_id):
