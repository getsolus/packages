From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Reilly Brogan <reilly@reillybrogan.com>
Date: Wed, 25 Mar 2026 16:40:19 -0500
Subject: [PATCH] fix: Don't install bindir if no user facing tools exist

https://invent.kde.org/qt/qt/qtbase/-/commit/1ce2841fc1695325f6213d213f2d8dbf5d653c18 made it so that user_facing_tool_links is called automatically as part of the install, which is good. However it's conditional on `INSTALL_PUBLICBINDIR` being set which means that for us on Aeryn who have that as part of our Qt cmake macros that it will run anyway, and since the first line is to create INSTALL_PUBLICBINDIR the end result is that bindir is created unnecessarily for Qt6 libs without tools.
---
 cmake/QtPostProcessHelpers.cmake | 5 ++++-
 1 file changed, 4 insertions(+), 1 deletion(-)

diff --git a/cmake/QtPostProcessHelpers.cmake b/cmake/QtPostProcessHelpers.cmake
index c69d57e19c4..cccd1af3de1 100644
--- a/cmake/QtPostProcessHelpers.cmake
+++ b/cmake/QtPostProcessHelpers.cmake
@@ -890,10 +890,13 @@ function(qt_internal_generate_user_facing_tools_info)
     get_property(user_facing_tool_targets GLOBAL PROPERTY QT_USER_FACING_TOOL_TARGETS)
     set(lines "")
     set(cmake_install_script "${PROJECT_BINARY_DIR}/install_user_facing_tool_links.cmake")
-    set(cmake_install_script_content
+    set(cmake_install_script_content "")
+    if(user_facing_tool_targets)
+        string(APPEND cmake_install_script_content
 "execute_process(COMMAND \"\${CMAKE_COMMAND}\" -E make_directory
     \"\$ENV{DESTDIR}\${CMAKE_INSTALL_PREFIX}/${INSTALL_PUBLICBINDIR}\")
 ")
+    endif()
     foreach(target ${user_facing_tool_targets})
         get_target_property(filename ${target} OUTPUT_NAME)
         if(NOT filename)
