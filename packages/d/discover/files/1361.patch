From c8d765175b2a4c84b0ff4545d1167fa0d70299fd Mon Sep 17 00:00:00 2001
From: Joey Riches <josephriches@gmail.com>
Date: Thu, 16 Jul 2026 18:39:31 +0100
Subject: [PATCH 1/2] packagekit: Show downloadSize() if pkg is upgradable

This ensures that the download size of the pkg is shown in the updates
view rather than the installed size when an update to the package is
available.
---
 .../backends/PackageKitBackend/PackageKitResource.cpp       | 6 +++++-
 1 file changed, 5 insertions(+), 1 deletion(-)

diff --git a/libdiscover/backends/PackageKitBackend/PackageKitResource.cpp b/libdiscover/backends/PackageKitBackend/PackageKitResource.cpp
index f2d91de30..c542a44dd 100644
--- a/libdiscover/backends/PackageKitBackend/PackageKitResource.cpp
+++ b/libdiscover/backends/PackageKitBackend/PackageKitResource.cpp
@@ -167,7 +167,11 @@ QString PackageKitResource::installedVersion() const
 quint64 PackageKitResource::size()
 {
     fetchDetails();
-    return m_details.size();
+    if (PackageKitResource::state() == Upgradeable) {
+        return m_details.downloadSize();
+    } else {
+        return m_details.size();
+    }
 }
 
 QString PackageKitResource::origin() const
-- 
