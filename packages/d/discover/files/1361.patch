From 0aa45d4a11a27794e844f3384b2200a36bac9a52 Mon Sep 17 00:00:00 2001
From: Joey Riches <josephriches@gmail.com>
Date: Thu, 16 Jul 2026 18:40:42 +0100
Subject: [PATCH 2/2] packagekit: Add sizeDescription() override for backend

Add sizeDescription() to ensure that the installed size of a package is
shown in the browsing view rather than falling back to size which may
show the download size rather than the installed size.

This mirrors what is done in the flatpak backend.
---
 .../backends/PackageKitBackend/PackageKitResource.cpp      | 7 +++++++
 .../backends/PackageKitBackend/PackageKitResource.h        | 1 +
 2 files changed, 8 insertions(+)

diff --git a/libdiscover/backends/PackageKitBackend/PackageKitResource.cpp b/libdiscover/backends/PackageKitBackend/PackageKitResource.cpp
index c542a44dd..5ec6d15da 100644
--- a/libdiscover/backends/PackageKitBackend/PackageKitResource.cpp
+++ b/libdiscover/backends/PackageKitBackend/PackageKitResource.cpp
@@ -12,6 +12,7 @@
 #include "appstream/AppStreamUtils.h"
 #include "config-paths.h"
 #include <AppStreamQt/spdx.h>
+#include <KFormat>
 #include <KIO/ApplicationLauncherJob>
 #include <KLocalizedString>
 #include <KService>
@@ -174,6 +175,12 @@ quint64 PackageKitResource::size()
     }
 }
 
+QString PackageKitResource::sizeDescription()
+{
+    fetchDetails();
+    return KFormat().formatByteSize(m_details.size());
+}
+
 QString PackageKitResource::origin() const
 {
     auto osRelease = AppStreamIntegration::global()->osRelease();
diff --git a/libdiscover/backends/PackageKitBackend/PackageKitResource.h b/libdiscover/backends/PackageKitBackend/PackageKitResource.h
index 534ce98f2..6a11a1c42 100644
--- a/libdiscover/backends/PackageKitBackend/PackageKitResource.h
+++ b/libdiscover/backends/PackageKitBackend/PackageKitResource.h
@@ -37,6 +37,7 @@ public:
     QString section() override;
     AbstractResource::Type type() const override;
     quint64 size() override;
+    QString sizeDescription() override;
     void fetchChangelog() override;
     void fetchUpdateDetails() override;
 
-- 
