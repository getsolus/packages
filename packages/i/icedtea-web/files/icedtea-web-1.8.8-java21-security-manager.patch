From a631a7d17a50a4a9ef0c6ecb584371dad749338e Mon Sep 17 00:00:00 2001
From: Robert Scheck <robert@fedoraproject.org>
Date: Sat, 3 May 2025 02:00:43 +0200
Subject: [PATCH] Prepend -Djava.security.manager as workaround for Java 21

The Java security manager is deprecated since Java 17 and disabled by default
since at least Java 21 (and subject to removal in a future release). For the
time being enabling the security manager (as a workaround) leads to a working
IcedTea-Web using Java 21.

Co-authored-by: Damien Raude-Morvan <drazzib@debian.org>
---
 rust-launcher/src/main.rs      | 1 +
 shell-launcher/launchers.sh.in | 3 +++
 2 files changed, 4 insertions(+)

diff --git a/rust-launcher/src/main.rs b/rust-launcher/src/main.rs
index d13e1a669..78dd551db 100644
--- a/rust-launcher/src/main.rs
+++ b/rust-launcher/src/main.rs
@@ -172,6 +172,7 @@ fn compose_arguments(java_dir: &std::path::PathBuf, original_args: &std::vec::Ve
     all_args.push(cp);
     all_args.push(bin_name);
     all_args.push(bin_location);
+    all_args.push(String::from("-Djava.security.manager"));
     all_args.push(hardcoded_paths::get_main().to_string());
 
     include_not_dashJs(&original_args, &mut all_args);
diff --git a/shell-launcher/launchers.sh.in b/shell-launcher/launchers.sh.in
index 97d0377da..bb0bd4117 100644
--- a/shell-launcher/launchers.sh.in
+++ b/shell-launcher/launchers.sh.in
@@ -188,6 +188,9 @@ k=$((k+1))
 COMMAND[k]="-Dicedtea-web.bin.location=${BINARY_LOCATION}"
 k=$((k+1))
 
+COMMAND[k]="-Djava.security.manager"
+k=$((k+1))
+
 COMMAND[k]="${CLASSNAME}"
 k=$((k+1))
 j=0
