Patch by Stephan Classen <st.classen@gmx.ch> for icedtea-web adding a dummy implementation of JarIndex to support Java 21+.
See also: https://bugs.debian.org/cgi-bin/bugreport.cgi?bug=1052691

Patch origin: https://github.com/AdoptOpenJDK/IcedTea-Web/pull/925

--- icedtea-web-1.8.8/netx/net/sourceforge/jnlp/jdk89acesses/JarIndexAccess.java	2021-10-27 22:13:18.000000000 +0200
+++ icedtea-web-1.8.8/netx/net/sourceforge/jnlp/jdk89acesses/JarIndexAccess.java.java21	2025-05-02 23:33:11.264189772 +0200
@@ -28,7 +28,7 @@
                 jarIndexClass = Class.forName("jdk.internal.util.jar.JarIndex");
             } catch (ClassNotFoundException exx) {
                 OutputController.getLogger().log(exx);
-                throw new RuntimeException("JarIndex not found!");
+                jarIndexClass = JarIndexDummy.class;
             }
         }
     }
@@ -71,4 +71,17 @@
         return (LinkedList<String>) o;
     }
 
+    /**
+     * Because starting of JAVA 21 the JarIndex is no longer supported we provide a dummy implementation which always returns {@code null}.
+     */
+    @SuppressWarnings("unused")
+    private static class JarIndexDummy {
+        public static Object getJarIndex(JarFile jar) {
+            return null;
+        }
+
+        public Object get(String fileName) {
+            return null;
+        }
+    }
 }
