<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <id>ivpn</id>

    <name>ivpn</name>
    <summary>A desktop VPN client that connects to IVPN&apos;s servers</summary>

    <metadata_license>CC0-1.0</metadata_license>
    <project_license>GPL-3.0-or-later</project_license>
    <url type="homepage">https://www.ivpn.net/en/apps-linux/</url>

    <supports>
        <control>pointing</control>
        <control>keyboard</control>
        <control>touch</control>
    </supports>

    <description>
        <p>
            IVPN for Desktop is the official IVPN app for desktop platforms.
        </p>
        <p>Some of the features include: multiple protocols (OpenVPN, WireGuard), Kill-switch, Multi-Hop, Trusted Networks, AntiTracker, Custom DNS, Dark mode, and more.</p>
    </description>

    <launchable type="desktop-id">IVPN.desktop</launchable>
    <screenshots>
        <screenshot type="default">
            <image>https://raw.githubusercontent.com/ivpn/desktop-app/refs/heads/development/.github/readme_images/ivpn_app_dark.png</image>
        </screenshot>
        <screenshot>
            <image>https://www.ivpn.net/images-static/uploads/apps/linux-app-3.3.7-dark@2x.png</image>
        </screenshot>
    </screenshots>
</component>