From 2d2539f4c7debf33c3a230b7d2aadedce9a756c6 Mon Sep 17 00:00:00 2001
From: Joey Riches <josephriches@gmail.com>
Date: Sun, 21 Jun 2026 12:41:01 +0100
Subject: [PATCH 1/1] sax: Add __builtin_expect to extremely hot if statement

In the while loop this dominates 26% of runtime
---
 src/sax.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/sax.c b/src/sax.c
index 68bddc5..5643cdc 100644
--- a/src/sax.c
+++ b/src/sax.c
@@ -430,7 +430,7 @@ sax_core (iksparser *prs, char *buf, int len)
 			goto cont;
 		} else {
 			unsigned char cl = char_class[c];
-			if (cl & B_UTF8) {
+			if (__builtin_expect (cl & B_UTF8, 0)) {
 				prs->uni_max = utf8_len[c];
 				if (0 == prs->uni_max) return IKS_BADXML;
 				prs->uni_char = c & utf8_mask[c];
-- 
