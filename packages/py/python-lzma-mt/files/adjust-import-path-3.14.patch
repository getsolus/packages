From 76daf2e7a5e4afc0ef5e5ff5d765d662e9217336 Mon Sep 17 00:00:00 2001
From: Joey Riches <josephriches@gmail.com>
Date: Sat, 30 May 2026 12:39:07 +0100
Subject: [PATCH] Adjust import path of private compression module for python
 3.14

https://github.com/python/cpython/pull/133018
---
 src/lzma_mt/__init__.py | 7 ++++++-
 1 file changed, 6 insertions(+), 1 deletion(-)

diff --git a/src/lzma_mt/__init__.py b/src/lzma_mt/__init__.py
index aa3729f..0e8bf43 100644
--- a/src/lzma_mt/__init__.py
+++ b/src/lzma_mt/__init__.py
@@ -12,16 +12,21 @@
 import builtins
 import io
 import os
+import sys
 
 # _compression is a private CPython module, may not exist in all versions
 try:
-    from _compression import BaseStream, DecompressReader
+    if sys.version_info >= (3, 14):
+        from compression._common._streams import BaseStream, DecompressReader
+    else:
+        from _compression import BaseStream, DecompressReader
 except ImportError:
     # Fallback implementations (copied from CPython's _compression.py)
     BUFFER_SIZE = io.DEFAULT_BUFFER_SIZE
 
     class BaseStream(io.BufferedIOBase):
         """Mode-checking helper functions."""
+
         def _check_not_closed(self):
             if self.closed:
                 raise ValueError("I/O operation on closed file")
