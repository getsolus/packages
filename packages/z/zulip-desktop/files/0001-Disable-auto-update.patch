From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Reilly Brogan <reilly@reillybrogan.com>
Date: Fri, 7 Nov 2025 13:47:12 -0600
Subject: [PATCH] Disable auto-update

---
 app/main/index.ts                                   | 2 +-
 app/renderer/js/main.ts                             | 2 +-
 app/renderer/js/pages/preference/general-section.ts | 6 +++---
 3 files changed, 5 insertions(+), 5 deletions(-)

diff --git a/app/main/index.ts b/app/main/index.ts
index cf70336..15705ac 100644
--- a/app/main/index.ts
+++ b/app/main/index.ts
@@ -285,7 +285,7 @@ function createMainWindow(): BrowserWindow {
 
   page.once("did-frame-finish-load", () => {
     // Initiate auto-updates on MacOS and Windows
-    if (ConfigUtil.getConfigItem("autoUpdate", true)) {
+    if (ConfigUtil.getConfigItem("autoUpdate", false)) {
       void appUpdater();
     }
   });
diff --git a/app/renderer/js/main.ts b/app/renderer/js/main.ts
index 4ee032a..214cd42 100644
--- a/app/renderer/js/main.ts
+++ b/app/renderer/js/main.ts
@@ -197,7 +197,7 @@ export class ServerManagerView {
       ["startMinimized", false],
       ["enableSpellchecker", true],
       ["showNotification", true],
-      ["autoUpdate", true],
+      ["autoUpdate", false],
       ["betaUpdate", false],
       ["errorReporting", true],
       ["customCSS", false],
diff --git a/app/renderer/js/pages/preference/general-section.ts b/app/renderer/js/pages/preference/general-section.ts
index 25bf781..e0d9f77 100644
--- a/app/renderer/js/pages/preference/general-section.ts
+++ b/app/renderer/js/pages/preference/general-section.ts
@@ -324,9 +324,9 @@ export function initGeneralSection({$root}: GeneralSectionProperties): void {
         ":scope #autoupdate-option .setting-control",
       )!,
       disabled: EnterpriseUtil.configItemExists("autoUpdate"),
-      value: ConfigUtil.getConfigItem("autoUpdate", true),
+      value: ConfigUtil.getConfigItem("autoUpdate", false),
       clickHandler() {
-        const newValue = !ConfigUtil.getConfigItem("autoUpdate", true);
+        const newValue = !ConfigUtil.getConfigItem("autoUpdate", false);
         ConfigUtil.setConfigItem("autoUpdate", newValue);
         if (!newValue) {
           ConfigUtil.setConfigItem("betaUpdate", false);
@@ -346,7 +346,7 @@ export function initGeneralSection({$root}: GeneralSectionProperties): void {
       value: ConfigUtil.getConfigItem("betaUpdate", false),
       clickHandler() {
         const newValue = !ConfigUtil.getConfigItem("betaUpdate", false);
-        if (ConfigUtil.getConfigItem("autoUpdate", true)) {
+        if (ConfigUtil.getConfigItem("autoUpdate", false)) {
           ConfigUtil.setConfigItem("betaUpdate", newValue);
           betaUpdateOption();
         }
