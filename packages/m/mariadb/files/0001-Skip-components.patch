From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Reilly Brogan <reilly@reillybrogan.com>
Date: Wed, 9 Jul 2025 14:04:25 -0500
Subject: [PATCH] Skip components

Allow -DSKIP_COMPONENTS=Test to skip test artifacts at install time.
---
 CMakeLists.txt | 6 +-----
 1 file changed, 1 insertion(+), 5 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index a7943f9899..1959b20c1b 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -185,11 +185,7 @@ ENDIF()
 ENDIF()
 OPTION (WITH_UNIT_TESTS "Compile MySQL with unit tests" ON)
 
-IF (WITHOUT_SERVER)
-  SET (SKIP_COMPONENTS "Server|IniFiles|SupportFiles|Readme")
-ELSE()
-  SET (SKIP_COMPONENTS "N-O-N-E")
-ENDIF()
+set(SKIP_COMPONENTS "N-O-N-E" CACHE STRING "Components to skip during install")
 
 
 SET(MEMPROTECT_DEFAULT ON)
