From 31acfa368c3669508924d124c27cd5fa07bf7053 Mon Sep 17 00:00:00 2001
From: "Brian J. Tarricone" <brian@tarricone.org>
Date: Sat, 2 Nov 2024 23:18:29 -0700
Subject: [PATCH] Fix build with just file icons disable or just desktop icons
 disabled

Closes #318
---
 configure.ac      | 11 ++++-------
 src/main.c        |  2 +-
 tests/Makefile.am |  4 ++++
 3 files changed, 9 insertions(+), 8 deletions(-)

diff --git a/configure.ac b/configure.ac
index 24c0e192a..d21cd05a6 100644
--- a/configure.ac
+++ b/configure.ac
@@ -119,19 +119,16 @@ dnl do we want desktop icons at all?
 AC_ARG_ENABLE([desktop-icons],
     [AS_HELP_STRING([--disable-desktop-icons],
             [Do not compile in support for desktop icons (default=enabled)])],
-        [ac_cv_enable_desktop_icons=$enableval],
-        [ac_cv_enable_desktop_icons=yes])
-if test "x$ac_cv_enable_desktop_icons" = "xno"; then
-    enable_desktop_icons="no"
-else
-    enable_desktop_icons="yes"
+        [enable_desktop_icons=$enableval],
+        [enable_desktop_icons=yes])
+if test "x$enable_desktop_icons" = "xyes"; then
     AC_DEFINE([ENABLE_DESKTOP_ICONS], [1], [Set if desktop icon support is enabled])
 fi
 AM_CONDITIONAL([ENABLE_DESKTOP_ICONS], [test "x$enable_desktop_icons" = "xyes"])
 
 dnl if we want desktop icons, do we also want file icons?
 if test x"$enable_desktop_icons" != x"yes"; then
-    xdt_cv_FILE_ICONS_enabled=no
+    enable_file_icons=no
 fi
 XDT_CHECK_OPTIONAL_FEATURE([FILE_ICONS],
                            [file-icons],
diff --git a/src/main.c b/src/main.c
index 242f06498..9cb2436bb 100644
--- a/src/main.c
+++ b/src/main.c
@@ -54,7 +54,7 @@ main(int argc, char **argv)
     /* bind gettext textdomain */
     xfce_textdomain(GETTEXT_PACKAGE, LOCALEDIR, "UTF-8");
 
-#ifdef ENABLE_DESKTOP_ICONS
+#ifdef ENABLE_FILE_ICONS
     xfdesktop_monitor_chooser_ui_register_resource();
 #endif
 
diff --git a/tests/Makefile.am b/tests/Makefile.am
index 6b7244d66..5ac4d5d55 100644
--- a/tests/Makefile.am
+++ b/tests/Makefile.am
@@ -1,5 +1,7 @@
 if ENABLE_TESTS
 
+if ENABLE_FILE_ICONS
+
 noinst_PROGRAMS = \
 	test-icon-position-parsing \
 	test-icon-position-saving
@@ -31,6 +33,8 @@ test_icon_position_saving_LDADD = $(tests_ldadd)
 
 endif
 
+endif
+
 EXTRA_DIST = \
 	meson.build \
 	test-icon-position-parsing.c \
-- 
GitLab

