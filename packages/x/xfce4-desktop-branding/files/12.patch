From 40192615ccffe1547ce32704218d091ea0201fae Mon Sep 17 00:00:00 2001
From: Evan Maddock <maddock.evan@vivaldi.net>
Date: Thu, 7 Nov 2024 17:48:00 -0500
Subject: [PATCH] overrides: Drop config for xfdesktop

We'll configure it via the build script instead.

Signed-off-by: Evan Maddock <maddock.evan@vivaldi.net>
---
 overrides/meson.build       |  5 -----
 overrides/xfce4-desktop.xml | 42 -------------------------------------
 2 files changed, 47 deletions(-)
 delete mode 100644 overrides/xfce4-desktop.xml

diff --git a/overrides/meson.build b/overrides/meson.build
index 8f21f45..e6dff9b 100644
--- a/overrides/meson.build
+++ b/overrides/meson.build
@@ -16,11 +16,6 @@ install_data(
   install_dir: xfconf_dir,
 )
 
-install_data(
-  'xfce4-desktop.xml',
-  install_dir: xfconf_dir,
-)
-
 install_data(
   'xfce4-notifyd.xml',
   install_dir: xfconf_dir,
diff --git a/overrides/xfce4-desktop.xml b/overrides/xfce4-desktop.xml
deleted file mode 100644
index 5b191ce..0000000
--- a/overrides/xfce4-desktop.xml
+++ /dev/null
@@ -1,42 +0,0 @@
-<?xml version="1.0" encoding="UTF-8"?>
-
-<channel name="xfce4-desktop" version="1.0">
-  <property name="desktop-icons" type="empty">
-    <property name="style" type="int" value="2"/>
-    <property name="file-icons" type="empty">
-      <property name="show-home" type="bool" value="true"/>
-      <property name="show-filesystem" type="bool" value="false"/>
-      <property name="show-removable" type="bool" value="false"/>
-      <property name="show-trash" type="bool" value="true"/>
-    </property>
-    <property name="icon-size" type="uint" value="48"/>
-    <property name="tooltip-size" type="double" value="64.000000"/>
-  </property>
-  <property name="backdrop" type="empty">
-    <property name="screen0" type="empty">
-      <property name="monitor0" type="empty">
-        <property name="image-path" type="string" value="/usr/share/backgrounds/solus/LakeSideView.jpg"/>
-        <property name="image-style" type="int" value="5"/>
-        <property name="image-show" type="bool" value="true"/>
-      </property>
-      <property name="monitor1" type="empty">
-        <property name="image-path" type="string" value="/usr/share/backgrounds/solus/LakeSideView.jpg"/>
-        <property name="image-style" type="int" value="5"/>
-        <property name="image-show" type="bool" value="true"/>
-      </property>
-      <property name="monitor2" type="empty">
-        <property name="image-path" type="string" value="/usr/share/backgrounds/solus/LakeSideView.jpg"/>
-        <property name="image-style" type="int" value="5"/>
-        <property name="image-show" type="bool" value="true"/>
-      </property>
-      <property name="monitor3" type="empty">
-        <property name="image-path" type="string" value="/usr/share/backgrounds/solus/LakeSideView.jpg"/>
-        <property name="image-style" type="int" value="5"/>
-        <property name="image-show" type="bool" value="true"/>
-      </property>
-    </property>
-  </property>
-  <property name="desktop-menu" type="empty">
-    <property name="show" type="bool" value="false"/>
-  </property>
-</channel>
\ No newline at end of file
