From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Evan Maddock <maddock.evan@vivaldi.net>
Date: Mon, 20 Apr 2026 16:05:21 -0400
Subject: [PATCH] build: Fix missing dep for pkgconfig and GIR

Fixes GtkLayerShell being missing from the dependency list when
generating the GIR and pkgconfig files for panel plugin.

Signed-off-by: Evan Maddock <maddock.evan@vivaldi.net>
---
 src/plugin/panel/meson.build | 6 ++++--
 1 file changed, 4 insertions(+), 2 deletions(-)

diff --git a/src/plugin/panel/meson.build b/src/plugin/panel/meson.build
index abdd5f98..cfb34ef4 100644
--- a/src/plugin/panel/meson.build
+++ b/src/plugin/panel/meson.build
@@ -76,6 +76,7 @@ libpanelplugin_gir = gnome.generate_gir(
         'Gio-2.0',
         'Gtk-3.0',
         'Peas-2',
+        'GtkLayerShell-0.1',
     ],
     symbol_prefix: 'budgie',
     identifier_prefix: 'Budgie',
@@ -108,10 +109,11 @@ pkgconfig.generate(
     subdirs: 'budgie-desktop',
     libraries: ['-L${libdir}', '-lbudgie-plugin'],
     requires: [
+        'gio-unix-2.0 >= 2.46.0',
+        'glib-2.0 >= 2.46.0',
         'gtk+-3.0 >= 3.24.0',
+        'gtk-layer-shell-0 >= 0.9.0',
         'libpeas-2 >= 1.99.0',
-        'glib-2.0 >= 2.46.0',
-        'gio-unix-2.0 >= 2.46.0',
     ],
 )
 
