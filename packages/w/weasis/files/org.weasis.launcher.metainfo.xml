  <name>Weasis</name>
  <summary>View and analyze DICOM medical images</summary>
  <description>
    <p>
      Weasis is a DICOM viewer for medical imaging. It can open local studies
      and integrate with PACS, DICOMweb, and other clinical imaging workflows.
    </p>
    <p>
      The viewer provides tools for image comparison, measurements,
      multiplanar reconstruction, and three-dimensional visualization.
    </p>
  </description>
  <launchable type="desktop-id">org.weasis.launcher.desktop</launchable>
  <provides>
    <binary>weasis</binary>
    <mediatype>application/dicom</mediatype>
  </provides>
  <url type="homepage">https://weasis.org/</url>
