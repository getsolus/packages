[Desktop Entry]
Type=Application
Version=1.0
Name=Weasis
GenericName=DICOM Viewer
Comment=View and analyze DICOM medical images
Exec=weasis %U
Icon=org.weasis.launcher
Terminal=false
Categories=Science;MedicalSoftware;Java;
