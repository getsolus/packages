From 9bb5594f3e33fd094ce3c4fb22d312c80a8f2d53 Mon Sep 17 00:00:00 2001
From: Joey Riches <josephriches@gmail.com>
Date: Wed, 3 Dec 2025 20:49:50 +0000
Subject: [PATCH 1/1] data: Allow disabling updating debug sections for bolt

Sometimes we have no or bad debug that bolt can choke on
---
 data/macros/actions/pgo.yaml | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/data/macros/actions/pgo.yaml b/data/macros/actions/pgo.yaml
index cc48bea..8a17321 100644
--- a/data/macros/actions/pgo.yaml
+++ b/data/macros/actions/pgo.yaml
@@ -30,7 +30,6 @@ actions:
     - bolt_opt: |
         boptim(){
             llvm-bolt ${1}.orig -o ${1}.bolt -data=$PKG_BUILD_DIR/BOLT/final/$(basename ${1}).fdata \
-                -update-debug-sections \
                 -reorder-blocks=ext-tsp \
                 -reorder-functions=hfsort+ \
                 -split-functions \
@@ -41,6 +40,7 @@ actions:
                 -use-gnu-stack \
                 -peepholes=all \
                 -frame-opt=hot \
+                $( [[ -z "$BOLT_NO_DEBUG_INFO" ]] && echo "-update-debug-sections \" )
                 -use-old-text ${2} ${3} ${4}
             cp ${1}.bolt ${1}
         }
-- 
2.52.0

