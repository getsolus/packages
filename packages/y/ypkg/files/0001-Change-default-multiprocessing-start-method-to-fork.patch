From 0d29ff4d73fe9bf3823dce4c9848d89d42ba7d84 Mon Sep 17 00:00:00 2001
From: Joey Riches <josephriches@gmail.com>
Date: Wed, 10 Jun 2026 00:00:23 +0100
Subject: [PATCH 1/2] Change default multiprocessing start method to "fork"

In python 3.14 it was changed to forkserver by default, however, it
seems we have issues with unpickablable pisi objects that get brought
into the ypkg context (possibly due to os.environ)

Therefore, stick with what works for now.
---
 ypkg2/main.py | 13 ++++++++++++-
 1 file changed, 12 insertions(+), 1 deletion(-)

diff --git a/ypkg2/main.py b/ypkg2/main.py
index cd7fc0e..fbee74f 100644
--- a/ypkg2/main.py
+++ b/ypkg2/main.py
@@ -11,9 +11,20 @@
 #  (at your option) any later version.
 #
 
+import multiprocessing
+import os
 import subprocess
 import sys
-import os
+
+# Set the multiprocessing start method to 'fork' if available.
+# This is to avoid issues with 'forkserver' and 'spawn' which require
+# all objects to be picklable, which is not the case for many
+# objects used in ypkg2/pisi.
+if hasattr(multiprocessing, "set_start_method"):
+    try:
+        multiprocessing.set_start_method("fork", force=True)
+    except RuntimeError:
+        pass
 
 import pisi.specfile
 from pisi.db.filesdb import FilesDB
