+++ b/src/dbus.c
@@ -0,0 +1,368 @@
+/*
+ * dbus - D-Bus support
+ *
+ * Copyright (c) 2026 Red Hat.
+ * Author: Jocelyn Falempe <jfalempe@redhat.com>
+ *
+ * Permission is hereby granted, free of charge, to any person obtaining
