From 6cdf4a7380304db6bb78cd57ad7bd3ebd5cc7a32 Mon Sep 17 00:00:00 2001
From: David Redondo <kde@david-redondo.de>
Date: Thu, 26 Feb 2026 16:34:13 +0100
Subject: [PATCH] Workaround crash due to QTBUG-144544

QQuickItemGrabResult has unsafe thread handling resulting in crashes
when we delete it before the result is ready. Workaround by keeping
the instances alive until they're ready.
SENTRY: PLASMA-WORKSPACE-21BB
BUG: 514098

(cherry picked from commit a6278dbe7969823c174f872494310b818107b87f)
---
 src/imagecolors.cpp | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/src/imagecolors.cpp b/src/imagecolors.cpp
index 4b6b4630c..fe0c24d59 100644
--- a/src/imagecolors.cpp
+++ b/src/imagecolors.cpp
@@ -238,9 +238,10 @@ void ImageColors::update()
     if (m_grabResult) {
         connect(m_grabResult.data(), &QQuickItemGrabResult::ready, this, [this, runUpdate]() {
             m_sourceImage = m_grabResult->image();
-            m_grabResult.clear();
             runUpdate();
         });
+        // Workaround for QTBUG-144544
+        connect(m_grabResult.data(), &QQuickItemGrabResult::ready, m_grabResult.data(), [grabResult = m_grabResult] {}, Qt::SingleShotConnection);
     }
 }
 
