From d1eb9f0534cb454b173ce758d84956aae52b507c Mon Sep 17 00:00:00 2001
From: Xaver Hugl <xaver.hugl@gmail.com>
Date: Wed, 16 Oct 2024 18:50:31 +0000
Subject: [PATCH] backends/drm: don't skip colorops when matching the pipeline

We combine all possible operations from the pipeline into one hardware color op,
there's no reason to skip any - it just prevents matching a pipeline that could
actually be represented in hardware just fine.

BUG: 494611


(cherry picked from commit d9ce40c06f3bfb4da84d59be9c3b358281f9aa40)

Co-authored-by: Xaver Hugl <xaver.hugl@gmail.com>
---
 src/backends/drm/drm_colorop.cpp | 1 -
 1 file changed, 1 deletion(-)

diff --git a/src/backends/drm/drm_colorop.cpp b/src/backends/drm/drm_colorop.cpp
index 50f30654393..e0944cacf95 100644
--- a/src/backends/drm/drm_colorop.cpp
+++ b/src/backends/drm/drm_colorop.cpp
@@ -73,7 +73,6 @@ bool DrmAbstractColorOp::matchPipeline(DrmAtomicCommit *commit, const ColorPipel
         if (!currentOp) {
             return false;
         }
-        currentOp = currentOp->next();
     }
 
     // now actually program the properties
