From 9284f43c86fd3fe3404462ea243c3b309c4eab69 Mon Sep 17 00:00:00 2001
From: Joey Riches <josephriches@gmail.com>
Date: Thu, 4 Jun 2026 20:30:35 +0100
Subject: [PATCH 1/1] Allow patchelf 0.18.0 on Solus

---
 nuitka/utils/SharedLibraries.py | 2 ++
 nuitka/utils/Utils.py           | 6 ++++++
 2 files changed, 8 insertions(+)

diff --git a/nuitka/utils/SharedLibraries.py b/nuitka/utils/SharedLibraries.py
index fad644d77..4173638a1 100644
--- a/nuitka/utils/SharedLibraries.py
+++ b/nuitka/utils/SharedLibraries.py
@@ -40,6 +40,7 @@ from .Utils import (
     isFedoraBasedLinux,
     isLinux,
     isMacOS,
+    isSolusBasedLinux,
     isSuseBasedLinux,
     isWin32Windows,
     raiseWindowsError,
@@ -520,6 +521,7 @@ def checkPatchElfPresenceAndUsability(logger):
         and not isAndroidBasedLinux()
         and not isFedoraBasedLinux()
         and not isSuseBasedLinux()
+        and not isSolusBasedLinux()
     ):
         return logger.sysexit(
             "Error, patchelf version %s is a known buggy release and cannot be used. Please upgrade or downgrade it."
diff --git a/nuitka/utils/Utils.py b/nuitka/utils/Utils.py
index 776295b1f..524a998e3 100644
--- a/nuitka/utils/Utils.py
+++ b/nuitka/utils/Utils.py
@@ -226,6 +226,12 @@ def isArchBasedLinux():
     return (base or dist_name) == "Arch"
 
 
+def isSolusBasedLinux():
+    dist_name, base, _dist_version = getLinuxDistribution()
+
+    return (base or dist_name) == "Solus"
+
+
 def isAndroidBasedLinux():
     # spell-checker: ignore googlesource
     if not isLinux():
