From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Reilly Brogan <reilly@reillybrogan.com>
Date: Sat, 7 Oct 2023 12:01:22 -0500
Subject: [PATCH] Use fully qualified app_id

---
 assets/neovide.desktop | 1 -
 src/cmd_line.rs        | 6 +++---
 src/window/mod.rs      | 2 +-
 3 files changed, 4 insertions(+), 5 deletions(-)

diff --git a/assets/neovide.desktop b/assets/neovide.desktop
index a39ec42..851d871 100644
--- a/assets/neovide.desktop
+++ b/assets/neovide.desktop
@@ -8,4 +8,3 @@ Categories=Utility;TextEditor;
 Comment=No Nonsense Neovim Client in Rust
 MimeType=text/english;text/plain;text/x-makefile;text/x-c++hdr;text/x-c++src;text/x-chdr;text/x-csrc;text/x-java;text/x-moc;text/x-pascal;text/x-tcl;text/x-tex;application/x-shellscript;text/x-c;text/x-c++;
 StartupNotify=true
-StartupWMClass=neovide
diff --git a/src/cmd_line.rs b/src/cmd_line.rs
index ce63a19..2c50eae 100644
--- a/src/cmd_line.rs
+++ b/src/cmd_line.rs
@@ -159,18 +159,18 @@ pub struct CmdLineSettings {
     pub neovim_bin: Option<String>,
 
     /// The app ID to show to the compositor (Wayland only, useful for setting WM rules)
-    #[arg(long = "wayland_app_id", env = "NEOVIDE_APP_ID", default_value = "neovide")]
+    #[arg(long = "wayland_app_id", env = "NEOVIDE_APP_ID", default_value = "dev.neovide.Neovide")]
     pub wayland_app_id: String,
 
     /// The class part of the X11 WM_CLASS property (X only, useful for setting WM rules)
-    #[arg(long = "x11-wm-class", env = "NEOVIDE_WM_CLASS", default_value = "neovide")]
+    #[arg(long = "x11-wm-class", env = "NEOVIDE_WM_CLASS", default_value = "dev.neovide.Neovide")]
     pub x11_wm_class: String,
 
     /// The instance part of the X11 WM_CLASS property (X only, useful for setting WM rules)
     #[arg(
         long = "x11-wm-class-instance",
         env = "NEOVIDE_WM_CLASS_INSTANCE",
-        default_value = "neovide"
+        default_value = "dev.neovide.Neovide"
     )]
     pub x11_wm_class_instance: String,
 
diff --git a/src/window/mod.rs b/src/window/mod.rs
index 8c96e51..07d8d8b 100644
--- a/src/window/mod.rs
+++ b/src/window/mod.rs
@@ -322,7 +322,7 @@ pub fn create_window(
 
         if env::var("WAYLAND_DISPLAY").is_ok() {
             let app_id = &cmd_line_settings.wayland_app_id;
-            WindowAttributesExtWayland::with_name(window_attributes, app_id.clone(), "neovide")
+            WindowAttributesExtWayland::with_name(window_attributes, app_id.clone(), "dev.neovide.Neovide")
         } else {
             let class = &cmd_line_settings.x11_wm_class;
             let instance = &cmd_line_settings.x11_wm_class_instance;
