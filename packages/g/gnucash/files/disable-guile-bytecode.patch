From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Jared Cervantes <jared@jaredcervantes.com>
Date: Sun, 21 Jun 2026 11:08:00 -0400
Subject: [PATCH] Disable build-time Guile byte-compilation

Guile 2.0.14 fails to resolve GnuCash's build-tree shared libraries when
compiling Scheme modules with guild, even when the generated command provides
LD_LIBRARY_PATH and GNC_MODULE_PATH. Keep the CMake target graph intact but
skip generating and installing precompiled .go files; install the Scheme
sources and let Guile compile them after installation instead.
---
 common/cmake_modules/GncAddSchemeTargets.cmake | 4 ++--
 1 file changed, 2 insertions(+), 2 deletions(-)

diff --git a/common/cmake_modules/GncAddSchemeTargets.cmake b/common/cmake_modules/GncAddSchemeTargets.cmake
index 9e9b2d2f49..f6e7b9d447 100644
--- a/common/cmake_modules/GncAddSchemeTargets.cmake
+++ b/common/cmake_modules/GncAddSchemeTargets.cmake
@@ -294,10 +294,11 @@ function(gnc_add_scheme_targets _TARGET)
       )
 
       add_custom_command(
         OUTPUT ${output_file}
+        COMMAND ${CMAKE_COMMAND} -E make_directory ${_GUILE_CACHE_DIR}/${SCHEME_TGT_OUTPUT_DIR}
         COMMAND ${CMAKE_COMMAND} -E env
             "${GUILE_ENV}$<$<CONFIG:Asan>:;${ASAN_DYNAMIC_LIB_ENV};ASAN_OPTIONS=${ASAN_BUILD_OPTIONS}>"
-            ${GUILE_EXECUTABLE} -e "\(@@ \(guild\) main\)" -s ${GUILD_EXECUTABLE} compile -o ${output_file} ${source_file_abs_path}
+            ${CMAKE_COMMAND} -E touch ${output_file}
         DEPENDS ${guile_depends}
         MAIN_DEPENDENCY ${source_file_abs_path}
         COMMAND_EXPAND_LISTS
@@ -314,7 +315,6 @@ function(gnc_add_scheme_targets _TARGET)
   if(SCHEME_TGT_TEST)
     add_dependencies(check ${_TARGET})
   else()
-    install(FILES ${_TARGET_FILES} DESTINATION ${GUILE_REL_SITECCACHEDIR}/${SCHEME_TGT_OUTPUT_DIR})
     install(FILES ${SCHEME_TGT_SOURCES} DESTINATION ${GUILE_REL_SITEDIR}/${SCHEME_TGT_OUTPUT_DIR})
   endif()
 endfunction()
