From c5b40cd2fe1803bad912d07bfc3cb12b0446313a Mon Sep 17 00:00:00 2001
From: Joey Riches <josephriches@gmail.com>
Date: Thu, 16 Jul 2026 17:07:44 +0100
Subject: [PATCH 1/2] packagekit: Remove "repos::repo-filename" check when
 refining repos

On non fedora like packagekit systems where `/etc/yum.d` doesn't exist
it would previously abort the repository refine job as filename would be
NULL.
---
 plugins/packagekit/gs-plugin-packagekit.c | 6 +-----
 1 file changed, 1 insertion(+), 5 deletions(-)

diff --git a/plugins/packagekit/gs-plugin-packagekit.c b/plugins/packagekit/gs-plugin-packagekit.c
index 30383dc7b..1370f83f5 100644
--- a/plugins/packagekit/gs-plugin-packagekit.c
+++ b/plugins/packagekit/gs-plugin-packagekit.c
@@ -2322,7 +2322,6 @@ gs_plugin_packagekit_refine_async (GsPlugin                   *plugin,
 	for (guint i = 0; i < gs_app_list_length (list); i++) {
 		GsApp *app = gs_app_list_index (list, i);
 		GPtrArray *sources;
-		const gchar *filename;
 
 		if (gs_app_has_quirk (app, GS_APP_QUIRK_IS_WILDCARD))
 			continue;
@@ -2334,10 +2333,7 @@ gs_plugin_packagekit_refine_async (GsPlugin                   *plugin,
 		n_considered++;
 
 		/* Repositories */
-		filename = gs_app_get_metadata_item (app, "repos::repo-filename");
-
-		if (gs_app_get_kind (app) == AS_COMPONENT_KIND_REPOSITORY &&
-		    filename != NULL) {
+		if (gs_app_get_kind (app) == AS_COMPONENT_KIND_REPOSITORY) {
 			gs_app_list_add (repos_list, app);
 		}
 
-- 
