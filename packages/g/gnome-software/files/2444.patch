From 8f3d11c49fc32e43cf8e6780aa78190dd6f5066e Mon Sep 17 00:00:00 2001
From: Joey Riches <josephriches@gmail.com>
Date: Thu, 16 Jul 2026 17:22:43 +0100
Subject: [PATCH 2/2] gs-repos-dialog: Disable refine result filtering for repo
 related apps

The refine job's finish_run() filters out AS_COMPONENT_KIND_REPOSITORY
apps via app_is_valid_filter, leaving the result list empty. This
prevents refine_sources_cb() from finding the repositories' installed
packages.

Use GS_PLUGIN_REFINE_FLAGS_DISABLE_FILTERING to preserve repos in the
result list so their related apps can be counted.
---
 src/gs-repos-dialog.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/src/gs-repos-dialog.c b/src/gs-repos-dialog.c
index 026bce885..9a2a7dd37 100644
--- a/src/gs-repos-dialog.c
+++ b/src/gs-repos-dialog.c
@@ -734,7 +734,8 @@ get_sources_cb (GsPluginLoader *plugin_loader,
 					  ADW_PREFERENCES_GROUP (section));
 	}
 
-	plugin_job = gs_plugin_job_refine_new (refine_list, GS_PLUGIN_REFINE_FLAGS_NONE, GS_PLUGIN_REFINE_REQUIRE_FLAGS_RELATED);
+	plugin_job = gs_plugin_job_refine_new (refine_list, GS_PLUGIN_REFINE_FLAGS_DISABLE_FILTERING,
+					    GS_PLUGIN_REFINE_REQUIRE_FLAGS_RELATED);
 	gs_plugin_loader_job_process_async (dialog->plugin_loader, plugin_job,
 					    dialog->cancellable,
 					    refine_sources_cb,
-- 
GitLab

