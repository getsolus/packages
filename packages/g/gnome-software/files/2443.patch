From e243fa43027827c9086ad319398f934cfcb97b7e Mon Sep 17 00:00:00 2001
From: Joey Riches <josephriches@gmail.com>
Date: Thu, 16 Jul 2026 16:58:21 +0100
Subject: [PATCH] packagekit: Early exit from repo refine loop when
 repo-filename is NULL

This fixes the Software Repositories dialog being slow to populate on
non-fedora like packagekit systems where `/etc/yum.d` doesn't exist.
---
 plugins/packagekit/gs-plugin-packagekit.c | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/plugins/packagekit/gs-plugin-packagekit.c b/plugins/packagekit/gs-plugin-packagekit.c
index 30383dc7b..a1eddfb72 100644
--- a/plugins/packagekit/gs-plugin-packagekit.c
+++ b/plugins/packagekit/gs-plugin-packagekit.c
@@ -2564,6 +2564,8 @@ gs_plugin_packagekit_refine_async (GsPlugin                   *plugin,
 				continue;
 
 			filename = gs_app_get_metadata_item (app, "repos::repo-filename");
+			if (filename == NULL)
+				continue;
 
 			sources = gs_app_get_sources (app);
 			if (!is_pk_apt_backend_broken && sources->len > 0) {
