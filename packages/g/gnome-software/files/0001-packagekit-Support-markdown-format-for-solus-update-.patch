From c683a16f7ba2b4005b5ad6b1da8f9af31e562efa Mon Sep 17 00:00:00 2001
From: Joey Riches <josephriches@gmail.com>
Date: Sun, 10 May 2026 00:26:32 +0100
Subject: [PATCH 1/1] packagekit: Support markdown format for solus update
 descriptions

---
 plugins/packagekit/gs-plugin-packagekit.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/plugins/packagekit/gs-plugin-packagekit.c b/plugins/packagekit/gs-plugin-packagekit.c
index c5975d733..07cb43495 100644
--- a/plugins/packagekit/gs-plugin-packagekit.c
+++ b/plugins/packagekit/gs-plugin-packagekit.c
@@ -2979,7 +2979,8 @@ get_update_detail_cb (GObject      *source_object,
 	 *
 	 */
 	is_markdown_desc = (gs_plugin_check_distro_id (plugin, "fedora") ||
-			    gs_plugin_check_distro_id (plugin, "rhel"));
+			    gs_plugin_check_distro_id (plugin, "rhel") ||
+			    gs_plugin_check_distro_id (plugin, "solus"));
 
 	/* set the update details for the update */
 	array = pk_results_get_update_detail_array (results);
