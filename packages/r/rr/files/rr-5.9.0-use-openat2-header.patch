From 4c7c66d4bad3c00e22dbcf45709c71feae8de655 Mon Sep 17 00:00:00 2001
From: Neal Gompa <neal@gompa.dev>
Date: Sat, 3 Jan 2026 10:37:33 -0500
Subject: [PATCH] Revert "Don't rely on linux/openat2.h"

This is now broken as of Linux 6.19.

This reverts commit aa2ef05cfd68af9ae45f0d05ef07a267749727f3.
---
 src/test/openat2.c | 2 ++
 src/test/util.h    | 8 --------
 2 files changed, 2 insertions(+), 8 deletions(-)

diff --git a/src/test/openat2.c b/src/test/openat2.c
index 22ed2b04..33b9d07a 100644
--- a/src/test/openat2.c
+++ b/src/test/openat2.c
@@ -2,6 +2,8 @@
 
 #include "util.h"
 
+#include <linux/openat2.h>  /* Definition of RESOLVE_* constants */
+
 #define TEST_DIR "test_dir"
 #define FILENAME "foo"
 #define REL_FILENAME "../" TEST_DIR "/" FILENAME
diff --git a/src/test/util.h b/src/test/util.h
index f7a751b7..2882aa5f 100644
--- a/src/test/util.h
+++ b/src/test/util.h
@@ -439,14 +439,6 @@ inline static SyscallWrapper get_spurious_desched_syscall(void) {
 #define RR_KCMP_FILE 0
 #define RR_KCMP_FILES 2
 
-/* Old systems don't have linux/openat2.h */
-struct open_how {
-	__u64 flags;
-	__u64 mode;
-	__u64 resolve;
-};
-#define RESOLVE_BENEATH	0x08
-
 /* Old systems don't have these */
 #ifndef TIOCGPKT
 #define TIOCGPKT _IOR('T', 0x38, int)
-- 
2.52.0

