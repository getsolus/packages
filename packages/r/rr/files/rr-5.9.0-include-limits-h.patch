From 1a3ad641b80a905f1e8eb93272b028b716e26d2e Mon Sep 17 00:00:00 2001
From: Aaron Merey <amerey@redhat.com>
Date: Wed, 29 Apr 2026 14:57:05 -0400
Subject: [PATCH] test: include <limits.h> in util.h for INT_MAX and friends

Several test files (futex_requeue.c, pidfd.c, sioc.c, readlink.c,
detach_state.c, blacklist.c, etc.) reference INT_MAX without
including <limits.h>. Older toolchains pulled it in transitively;
gcc 16 / glibc 2.43+ don't, breaking the build.

Add the include to util.h, which every test already includes, so
all current and future users are covered in one place.
---
 src/test/util.h | 1 +
 1 file changed, 1 insertion(+)

diff --git a/src/test/util.h b/src/test/util.h
index 7d5172de..eb60103b 100644
--- a/src/test/util.h
+++ b/src/test/util.h
@@ -26,6 +26,7 @@
 #include <fcntl.h>
 #include <grp.h>
 #include <inttypes.h>
+#include <limits.h>
 #include <linux/aio_abi.h>
 #include <linux/audit.h>
 #include <linux/capability.h>
-- 
2.53.0

