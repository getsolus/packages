From 4c16e50a7022af45f0c7bc520eb45608ccee1657 Mon Sep 17 00:00:00 2001
From: Gavin Zhao <git@gzgz.dev>
Date: Fri, 13 Feb 2026 23:55:25 -0500
Subject: [PATCH 1/3] rocr-runtime: Build shared libhsakmt

---
 projects/rocr-runtime/libhsakmt/CMakeLists.txt                | 2 +-
 projects/rocr-runtime/libhsakmt/src/libhsakmt.ver             | 3 +++
 projects/rocr-runtime/runtime/hsa-runtime/CMakeLists.txt      | 2 +-
 .../runtime/hsa-runtime/hsa-runtime64-config.cmake.in         | 4 +++-
 4 files changed, 8 insertions(+), 3 deletions(-)

diff --git a/projects/rocr-runtime/libhsakmt/CMakeLists.txt b/projects/rocr-runtime/libhsakmt/CMakeLists.txt
index 25b3af4af8..6d43897dbb 100644
--- a/projects/rocr-runtime/libhsakmt/CMakeLists.txt
+++ b/projects/rocr-runtime/libhsakmt/CMakeLists.txt
@@ -134,7 +134,7 @@ set ( HSAKMT_SRC "src/debug.c"
                  "src/kfdcontext.c")
 
 ## Declare the library target name
-add_library (${HSAKMT_TARGET} STATIC "")
+add_library (${HSAKMT_TARGET} "")
 
 ## Add sources
 target_sources ( ${HSAKMT_TARGET} PRIVATE ${HSAKMT_SRC} )
diff --git a/projects/rocr-runtime/libhsakmt/src/libhsakmt.ver b/projects/rocr-runtime/libhsakmt/src/libhsakmt.ver
index 357c7b04d9..9b8ae91835 100644
--- a/projects/rocr-runtime/libhsakmt/src/libhsakmt.ver
+++ b/projects/rocr-runtime/libhsakmt/src/libhsakmt.ver
@@ -18,6 +18,7 @@ hsaKmtQueryEventState;
 hsaKmtWaitOnEvent;
 hsaKmtWaitOnMultipleEvents;
 hsaKmtCreateQueue;
+hsaKmtCreateQueueExt;
 hsaKmtUpdateQueue;
 hsaKmtDestroyQueue;
 hsaKmtSetQueueCUMask;
@@ -30,6 +31,7 @@ hsaKmtRegisterMemory;
 hsaKmtRegisterMemoryToNodes;
 hsaKmtRegisterMemoryWithFlags;
 hsaKmtRegisterGraphicsHandleToNodes;
+hsaKmtRegisterGraphicsHandleToNodesExt;
 hsaKmtShareMemory;
 hsaKmtRegisterSharedHandle;
 hsaKmtRegisterSharedHandleToNodes;
@@ -90,6 +92,7 @@ hsaKmtPcSamplingStart;
 hsaKmtPcSamplingStop;
 hsaKmtPcSamplingSupport;
 hsaKmtAisReadWriteFile;
+hsaKmtModelEnabled;
 local: *;
 };
 
diff --git a/projects/rocr-runtime/runtime/hsa-runtime/CMakeLists.txt b/projects/rocr-runtime/runtime/hsa-runtime/CMakeLists.txt
index cfcd3fba3d..0285d392d7 100644
--- a/projects/rocr-runtime/runtime/hsa-runtime/CMakeLists.txt
+++ b/projects/rocr-runtime/runtime/hsa-runtime/CMakeLists.txt
@@ -347,7 +347,7 @@ endif()
 # Link to hsakmt-staticdrm target for static library builds
 if( BUILD_SHARED_LIBS )
   if (UNIX)
-    target_link_libraries ( ${CORE_RUNTIME_TARGET} PRIVATE hsakmt::hsakmt PkgConfig::drm)
+    target_link_libraries ( ${CORE_RUNTIME_TARGET} PUBLIC hsakmt::hsakmt PRIVATE PkgConfig::drm)
     if( BUILD_THUNK_VIRTIO )
       message(STATUS "Building with virtio support")
       target_link_libraries ( ${CORE_RUNTIME_TARGET} PRIVATE hsakmt_virtio)
diff --git a/projects/rocr-runtime/runtime/hsa-runtime/hsa-runtime64-config.cmake.in b/projects/rocr-runtime/runtime/hsa-runtime/hsa-runtime64-config.cmake.in
index 5bcded18a6..846a9b62d9 100644
--- a/projects/rocr-runtime/runtime/hsa-runtime/hsa-runtime64-config.cmake.in
+++ b/projects/rocr-runtime/runtime/hsa-runtime/hsa-runtime64-config.cmake.in
@@ -44,13 +44,15 @@
 
 include( CMakeFindDependencyMacro )
 
+# hsakmt is always required as it's a public dependency
+find_dependency(hsakmt 1.0)
+
 # Client apps only need our private dependencies if rocr is a static lib.
 set( _is_hsa_runtime_dynamic @BUILD_SHARED_LIBS@ )
 if( NOT _is_hsa_runtime_dynamic )
 
   set(CMAKE_MODULE_PATH ${CMAKE_MODULE_PATH} "${CMAKE_CURRENT_LIST_DIR}")
 
-  find_dependency(hsakmt 1.0)
   if (UNIX)
     find_dependency(LibElf)
   endif()
-- 
2.52.0

