From 5488017a8da0a7d6fd53b940bb1c35e895c67532 Mon Sep 17 00:00:00 2001
From: Joey Riches <josephriches@gmail.com>
Date: Wed, 22 Jul 2026 21:28:09 +0100
Subject: [PATCH 1/1] FFmpegVulkanVideoDecoder: Remove NVIDIA modifiers hack

Some formats such as VK_FORMAT_G8_B8R8_2PLANE_420_UNORM only support
LINEAR (e.g. nvidia 580 pascal). Forcing NVIDIA_BLOCK_LINEAR breaks the
vulkan video decoding process.
---
 dom/media/platforms/ffmpeg/FFmpegVulkanVideoDecoder.cpp | 7 -------
 1 file changed, 7 deletions(-)

diff --git a/dom/media/platforms/ffmpeg/FFmpegVulkanVideoDecoder.cpp b/dom/media/platforms/ffmpeg/FFmpegVulkanVideoDecoder.cpp
index dfb8017cfd9c..f59e21526555 100644
--- a/dom/media/platforms/ffmpeg/FFmpegVulkanVideoDecoder.cpp
+++ b/dom/media/platforms/ffmpeg/FFmpegVulkanVideoDecoder.cpp
@@ -432,13 +432,6 @@ void FFmpegVideoDecoder<LIBAV_VER>::FFmpegVulkanVideoDecoder::InitDrmModifiers(
     FFMPEGV_LOG("[VULKAN] No suitable modifiers found, using LINEAR");
   }
 
-  // NVIDIA: query may not expose tiled modifiers, add known-working one if RDD
-  // and GPU share the same device (only when we had a real compositor list).
-  if (aCompositorMods && mNegotiatedCompositorDecoderVendorID == 0x10de &&
-      mDecoderMatchesCompositor && mDrmModifiers[0] == DRM_FORMAT_MOD_LINEAR) {
-    mDrmModifiers[0] = DRM_FORMAT_MOD_NVIDIA_BLOCK_LINEAR_2D(0, 1, 2, 6, 4);
-  }
-
   FFMPEGV_LOG("[VULKAN] Using {} modifiers, first=0x{:x}", mDrmModifiers.size(),
               (unsigned long long)mDrmModifiers[0]);
 }
