-
-if grep bar.pcf "$TESTRESULT2" > /dev/null; then : ; else
-    echo "*** Test failed: $TEST"
-    echo "file property doesn't point to the expected file."
-    cat "$TESTRESULT2"
-    exit 1
-fi
-
