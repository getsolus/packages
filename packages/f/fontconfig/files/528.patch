-    exit 1
-fi
-
-rm -rf "$TESTFONT1DIR" "$TESTFONT2DIR" "$TESTCACHE1DIR" "$TESTCACHE2DIR" "$TESTBUILD1DIR" "$TESTBUILD2DIR"
-rm -f "$TESTRESULT1" "$TESTRESULT2"
-
-TEST=""
