-#! /bin/sh
-# -*- sh -*-
-# Copyright (C) 2023 fontconfig Authors
-# SPDX-License-Identifier: MIT
-
-. $(dirname $0)/functions
-
-dotest "Remap - same family name but different filename"
-prep
